\end_layout

\begin_layout Plain Layout

series x = YGA		# output gap
\end_layout

\begin_layout Plain Layout

scalar h = 11		# set max.
 forecast horizon
\end_layout

\begin_layout Plain Layout

\end_layout

\begin_layout Plain Layout

# SMEANF
\end_layout

\begin_layout Plain Layout

smean = smeanf(x, h) 
\end_layout

\begin_layout Plain Layout

print smean
\end_layout

\begin_layout Plain Layout

fcplot(x, smean, "Seasonal Mean Forecast")
\end_layout

\begin_layout Plain Layout

\end_layout

\begin_layout Plain Layout

# RW with drift
\end_layout

\begin_layout Plain Layout

rwd = rwf(x, h, 1)
\end_layout

\begin_layout Plain Layout

print rwd
\end_layout

\begin_layout Plain Layout

fcplot(x, rwd, "Random-Walk + Drift Forecast")
\end_layout

\begin_layout Plain Layout

\end_layout

\begin_layout Plain Layout

# Average of Forecasts
\end_layout

\begin_layout Plain Layout

avg_fc = avgfc(x, h)
\end_layout

\begin_layout Plain Layout

print avg_fc		# 1st col: point forecast, 2nd col: std.
